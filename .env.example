# Copy to .env (per Hermes profile, as needed) and fill in. NEVER commit .env.
# These are consumed by your Hermes profiles, not by the engine directly.

# --- Gate channel: Telegram (orchestrator profile) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # your Telegram user id
TELEGRAM_HOME_CHANNEL=           # chat/channel id for outbound proposals + reports

# --- Web search for scouts (scout profiles) ---
# Provide whichever backend your Hermes web toolset uses.
TAVILY_API_KEY=
# SERPER_API_KEY=
# BRAVE_API_KEY=

# --- Engine overrides (optional; defaults derive from triage.yaml) ---
# TRIAGE_CONFIG=triage.yaml
# TRIAGE_VAULT_DIR=./work/vault/items
# HERMES_KANBAN_DB=               # normally injected by the dispatcher per task
